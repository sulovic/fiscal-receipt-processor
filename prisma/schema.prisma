generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model FiscalReceipt {
  id                   Int       @id @default(autoincrement())
  receiptNumber        String    @unique
  shipmentNumber       String
  receiptIssueDate     DateTime
  country              Countries
  nameSurname          String
  address              String
  phoneNumber          String
  externalLink         String    @unique
  dateReceiptCollected DateTime  @default(now())
  dateSent             DateTime?

  @@index([receiptNumber, nameSurname, address])
}

enum Countries {
  SRBIJA
  CRNA_GORA
}
